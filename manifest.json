{
  "manifest_version": 2,
  "name": "__MSG_extensionName__",
  "version": "1.0.6",
  "default_locale": "en",
  "description": "__MSG_extensionDescription__",
  "browser_specific_settings": {
    "gecko": {
      "id": "notebooklm-clipper-tb@mtfkarukera.dev",
      "strict_min_version": "115.0"
    }
  },
  "background": {
    "scripts": [
      "src/shared/utils.js",
      "src/background/api/auth.js",
      "src/background/api/rpc_client.js",
      "src/background/background.js"
    ]
  },
  "message_display_action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "__MSG_actionTitle__",
    "default_icon": {
      "48": "icons/icon.png",
      "128": "icons/icon-128.png"
    }
  },
  "permissions": [
    "messagesRead",
    "accountsRead",
    "storage",
    "cookies",
    "downloads",
    "scripting",
    "sensitiveDataUpload",
    "*://*.google.com/*"
  ],
  "content_security_policy": "script-src 'self'; object-src 'none';",
  "icons": {
    "48": "icons/icon.png",
    "128": "icons/icon-128.png"
  }
}